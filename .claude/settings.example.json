{
  "_note": "Permissions and hooks here are tuned for this docs-only governance repository. Adapt for code repos: narrow the markdownlint hook to changed files only, add git push only if your workflow requires auto-push, and review the deny list against your team's branching workflow.",
  "permissions": {
    "allow": [
      "Bash:git status*",
      "Bash:git diff*",
      "Bash:git log*",
      "Bash:git add*",
      "Bash:git commit*",
      "Bash:markdownlint *"
    ],
    "deny": [
      "Bash:rm -rf*",
      "Bash:git reset --hard*",
      "Bash:git push --force*",
      "Bash:git push -f*",
      "Bash:git clean -f*",
      "Bash:git branch -D*",
      "Bash:git checkout -- *"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "markdownlint \"**/*.md\" --ignore node_modules",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
